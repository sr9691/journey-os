# Content Intelligence System - Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# WordPress Integration
WORDPRESS_BASE_URL=https://your-site.com
WORDPRESS_API_KEY=your-wordpress-api-key

# WordPress Application Passwords (required for Phase 1+)
# Create at: WordPress Admin > Users > Your Profile > Application Passwords
# These provide Basic Auth to satisfy current_user_can() on REST endpoints
WORDPRESS_APP_USER=your-wp-username
WORDPRESS_APP_PASSWORD=your-app-password

# Optional
API_TIMEOUT_SECONDS=30
